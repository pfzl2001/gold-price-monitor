# ===========================
# 邮件通知配置（Resend SMTP）
# ===========================
# 注册 https://resend.com 获取 API Key（免费额度：每月 3000 封）
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USER=resend
SMTP_PASS=re_your_resend_api_key_here
SENDER_EMAIL=noreply@mail.yourdomain.com
EMAIL_TO=your_email@example.com
EMAIL_SUBJECT=🔔 金价买入提醒

# ===========================
# 金价监控配置
# ===========================
GOLD_TZ=Asia/Shanghai
GOLD_CODE=CZB-JCJ
TRUST_ENV=0
TIMEOUT_SECONDS=15

# ===========================
# 通知防刷屏参数
# ===========================
NOTIFY_COOLDOWN_HOURS=2
NOTIFY_DROP_PCT=0.5

# ===========================
# 高级配置（一般无需修改）
# ===========================
# RESAMPLE_MINUTES=8
# RESAMPLE_MAX_STEPS=5000
# HISTORY_MAX_LINES=5000
